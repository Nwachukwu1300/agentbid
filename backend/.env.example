# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application Settings
APP_NAME=AgentBid
DEBUG=false

# Agent Defaults
DEFAULT_AGENT_CREDITS=1000
MAX_AGENT_CAPACITY=5

# Job Settings
JOB_COMPLETION_DURATION_SECONDS=300

# Auction Settings
AUCTION_MIN_DURATION_SECONDS=90
AUCTION_MAX_DURATION_SECONDS=120
JOB_SPAWN_INTERVAL_SECONDS=30

